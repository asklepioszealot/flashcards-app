{
  "name": "flashcards-app",
  "version": "1.0.0",
  "description": "Modüler, JSON-tabanlı ve dinamik set yönetimli pediatri çalışma uygulaması.   Kartları çevirerek soru-cevap çalışabilir, kartları değerlendirebilir ve farklı konu setlerini yöneterek ilerlemenizi takip edebilirsiniz.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dist": "npm run build",
    "preview": "vite preview",
    "serve:dist": "npm run preview -- --host 127.0.0.1 --port 4173 --strictPort",
    "web": "npm run dev",
    "backup:cloud-user": "node ./tools/backup-cloud-user.mjs",
    "backup:supabase": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./tools/backup-supabase.ps1",
    "backup:supabase:dry": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./tools/backup-supabase.ps1 -DryRun",
    "tauri": "node ./node_modules/@tauri-apps/cli/tauri.js",
    "build:desktop": "node ./node_modules/@tauri-apps/cli/tauri.js build --bundles nsis",
    "release": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./tools/build-release.ps1 -NoLegacyCopy",
    "release:no-legacy": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./tools/build-release.ps1 -NoLegacyCopy",
    "release:with-legacy": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./tools/build-release.ps1",
    "validate:set": "node ./tools/validate-set.js",
    "validate:set:strict": "node ./tools/validate-set.js --require-files",
    "test:smoke": "node ./tools/run-smoke.js",
    "test:smoke:headed": "node ./tools/run-smoke.js --headed",
    "test:smoke:install": "npx playwright install chromium",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test": "npm run test:smoke && npm run test:unit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asklepioszealot/flashcards-app.git"
  },
  "keywords": ["flashcards", "spaced-repetition", "study", "medical", "pediatri"],
  "author": "AsklepiosZealot",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/asklepioszealot/flashcards-app/issues"
  },
  "homepage": "https://github.com/asklepioszealot/flashcards-app#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "jsdom": "^29.0.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "dompurify": "^3.3.3",
    "fflate": "^0.8.2",
    "sql.js": "^1.14.1"
  }
}
